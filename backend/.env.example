# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ─── Base de données ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
DB_NAME=la-bobine

# ─── Authentification ─────────────────────────────────────────────────────────
JWT_SECRET=CHANGEZ_MOI_secret_tres_long_et_complexe
JWT_EXPIRES_IN=30d

# ─── Upload fichiers ──────────────────────────────────────────────────────────
MAX_UPLOAD_MB=10

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ─── IA ───────────────────────────────────────────────────────────────────────
# Provider : openai | replicate
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...votre_cle_openai...
OPENAI_MODEL=gpt-4o

# Pour Replicate (upscaling avancé — décommenter si utilisé)
# AI_PROVIDER=replicate
# REPLICATE_API_TOKEN=r8_...votre_token_replicate...
